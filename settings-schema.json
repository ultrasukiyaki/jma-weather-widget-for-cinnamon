{
  "location-section": {
    "type": "section",
    "description": "地域"
  },
  "office-code": {
    "type": "entry",
    "default": "130000",
    "description": "気象庁の府県予報区コード",
    "tooltip": "東京都は130000。別地域は気象庁のforecast JSONコードを指定します。"
  },
  "forecast-area-name": {
    "type": "entry",
    "default": "東京地方",
    "description": "予報エリア名"
  },
  "temperature-area-name": {
    "type": "entry",
    "default": "東京",
    "description": "気温観測地点名"
  },
  "display-location-name": {
    "type": "entry",
    "default": "府中市",
    "description": "表示する地域名"
  },
  "details-url": {
    "type": "entry",
    "default": "https://tenki.jp/forecast/3/16/4410/13206/1hour.html",
    "description": "詳しい予報を開くURL"
  },
  "display-section": {
    "type": "section",
    "description": "表示"
  },
  "panel-mode": {
    "type": "combobox",
    "default": "detailed",
    "description": "パネル表示",
    "options": {
      "アイコンのみ": "icon",
      "アイコン＋気温": "compact",
      "アイコン＋気温＋降水確率": "detailed"
    }
  },
  "update-interval": {
    "type": "spinbutton",
    "default": 30,
    "min": 10,
    "max": 180,
    "step": 5,
    "units": "分",
    "description": "更新間隔"
  },
  "notification-section": {
    "type": "section",
    "description": "通知・警告"
  },
  "rain-notification": {
    "type": "switch",
    "default": true,
    "description": "降水確率が高いとき通知"
  },
  "rain-threshold": {
    "type": "spinbutton",
    "default": 60,
    "min": 10,
    "max": 100,
    "step": 10,
    "units": "%",
    "description": "雨通知のしきい値"
  },
  "heat-warning": {
    "type": "switch",
    "default": true,
    "description": "高温時にパネルへ警告表示"
  },
  "heat-threshold": {
    "type": "spinbutton",
    "default": 35,
    "min": 28,
    "max": 42,
    "step": 1,
    "units": "℃",
    "description": "暑さ警告のしきい値",
    "tooltip": "公式の熱中症警戒アラートではなく、予想最高気温に基づく簡易警告です。"
  }
}
